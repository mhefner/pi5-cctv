# RTSP stream URLs — edit these before running view.sh
CAM1_URL="rtsp://user:pass@192.168.1.x/stream"   # 180° wide-angle cam (left panel)
CAM2_URL="rtsp://user:pass@192.168.1.x/stream"   # Regular cam (right panel)

# Codec per camera: h264 or h265
CAM1_CODEC=h264
CAM2_CODEC=h265

# TV output resolution — confirm with: modetest | grep connected
TV_WIDTH=1920
TV_HEIGHT=1080

# Layout: CAM1 gets left 2/3 of screen, CAM2 gets right 1/3
# Adjust these to taste — widths must sum to TV_WIDTH
CAM1_X=0
CAM1_Y=0
CAM1_W=1280
CAM1_H=1080

CAM2_X=1280
CAM2_Y=0
CAM2_W=640
CAM2_H=1080
